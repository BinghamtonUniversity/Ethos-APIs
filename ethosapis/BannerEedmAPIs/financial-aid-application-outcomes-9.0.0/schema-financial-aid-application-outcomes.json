{
  "title": "Financial Aid Application Outcomes",
  "description": "The analysis results of applicants' financial aid applications.",
  "type": "object",
  "properties": {
    "metadata": {
      "title": "Metadata",
      "description": "Metadata about the JSON payload",
      "type": "object",
      "properties": {
        "createdBy": {
          "title": "Created By",
          "description": "The name of the originator (user or system) of the data. This is informational only, do not use in business logic!",
          "type": "string"
        },
        "createdOn": {
          "title": "Created On",
          "description": "The date and time when the entity instance was created",
          "oneOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "modifiedBy": {
          "title": "Modified By",
          "description": "The name of the modifier (user or system) of the data. This is informational only, do not use in business logic!",
          "type": "string"
        },
        "modifiedOn": {
          "title": "Modified On",
          "description": "The date and time when the entity instance was last modified",
          "oneOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "id": {
      "title": "ID",
      "description": "The global identifier of the financial aid application outcome.",
      "type": "string",
      "format": "guid",
      "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
    },
    "applicant": {
      "title": "Applicant",
      "description": "The person who applied for financial aid.",
      "type": "object",
      "properties": {
        "person": {
          "title": "Person",
          "description": "A reference link to the common Persons entity for an applicant who is known to the student information system.",
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "id": {
                  "title": "ID",
                  "description": "The global identifier for the Person.",
                  "type": "string",
                  "format": "guid",
                  "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                }
              },
              "additionalProperties": false,
              "required": [
                "id"
              ]
            },
            {
              "type": "object",
              "maxProperties": 0
            }
          ]
        },
        "financialAidApplicant": {
          "title": "Financial Aid Applicant",
          "description": "A reference link to the Financial Aid Applicants entity for an applicant who may not be known to the student information system.",
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "id": {
                  "title": "ID",
                  "description": "The global identifier for the Financial Aid Applicant.",
                  "type": "string",
                  "format": "guid",
                  "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                }
              },
              "additionalProperties": false,
              "required": [
                "id"
              ]
            },
            {
              "type": "object",
              "maxProperties": 0
            }
          ]
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "aidYear": {
      "title": "Aid Year",
      "description": "The financial aid year for which the applicant applied.",
      "type": "object",
      "properties": {
        "id": {
          "title": "ID",
          "description": "The global identifier for the Aid Year.",
          "type": "string",
          "format": "guid",
          "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    },
    "methodology": {
      "title": "Methodology",
      "description": "The methodology used to analyze the application.",
      "enum": [
        "institutional",
        "federal",
        "institutionalFederal"
      ],
      "type": "string"
    },
    "application": {
      "title": "Application",
      "description": "The application analyzed to generate the outcome.",
      "type": "object",
      "properties": {
        "id": {
          "title": "ID",
          "description": "The global identifier for the Application.",
          "type": "string",
          "format": "guid",
          "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    },
    "rejectionStatus": {
      "title": "Rejection Status",
      "description": "An indication if the financial aid application has been rejected.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "rejected",
            "notRejected"
          ]
        },
        {
          "type": "string",
          "maxLength": 0
        }
      ]
    },
    "studentAidReportResolution": {
      "title": "Student Aid Report Resolution",
      "description": "An indication that the SAR C flag has been set and requires resolution.",

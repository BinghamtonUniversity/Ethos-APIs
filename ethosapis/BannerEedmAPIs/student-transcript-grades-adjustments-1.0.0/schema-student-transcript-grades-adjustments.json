                    "id": {
                      "title": "ID",
                      "description": "The global identifier for the Final Grade.",
                      "type": "string",
                      "format": "guid",
                      "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"

            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "modifiedBy": {
          "title": "Modified By",
          "description": "The name of the modifier (user or system) of the data. This is informational only, do not use in business logic!",
          "type": "string"
        },
        "modifiedOn": {
          "title": "Modified On",
          "description": "The date and time when the entity instance was last modified",

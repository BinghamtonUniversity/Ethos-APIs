{
    "title": "External Admissions Application Decision Statuses",
    "description": "Status of the decisions made on the Applications",
    "version": "1.2.0",
    "type": "object",
    "properties": {
        "metadata": {
            "title": "Metadata",
            "description": "Metadata about the JSON payload",
            "type": "object",
            "properties": {
                "createdBy": {
                    "title": "Created By",
                    "description": "The name of the originator (user or system) of the data. This is informational only, do not use in business logic!",
                    "type": "string"
                },
                "createdOn": {
                    "title": "Created On",
                    "description": "The date and time when the entity instance was created",
                    "oneOf": [
                        {
                            "type": "string",
                            "format": "date-time",
                            "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
                        },
                        {
                            "type": "string",
                            "maxLength": 0
                        }
                    ]
                },
                "modifiedBy": {
                    "title": "Modified By",
                    "description": "The name of the modifier (user or system) of the data. This is informational only, do not use in business logic!",
                    "type": "string"
                },
                "modifiedOn": {
                    "title": "Modified On",
                    "description": "The date and time when the entity instance was last modified",
                    "oneOf": [
                        {
                            "type": "string",
                            "format": "date-time",
                            "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
                        },
                        {
                            "type": "string",
                            "maxLength": 0
                        }
                    ]
                }
            },
            "additionalProperties": false
        },
        "admissionDecision": {
            "title": "Admission Decision",
            "description": "Decisions made on admission applications.",
            "type": "object",
            "properties": {
                "id": {
                    "title": "ID",
                    "description": "The global identifier for the Admission Decision.",
                    "type": "string",
                    "format": "guid",
                    "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                }
            },
            "links": [
                {
                    "rel": "self",
                    "href": "/admission-decisions/{id}",
                    "targetSchema": {
                        "$ref": "admission-decisions.json#"
                    }
                }
            ],
            "additionalProperties": false,
            "required": [
                "id"
            ]
        },
        "admissionInterview": {
            "title": "Admission Interview",
            "description": "The global identifier of the interview for the admission application.",
            "type": "object",
            "properties": {
                "id": {
                    "title": "ID",
                    "description": "The global identifier for the Admission Interview.",
                    "type": "string",
                    "format": "guid",
                    "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                }
            },
            "links": [
                {
                    "rel": "self",
                    "href": "/admission-interviews/{id}",
                    "targetSchema": {
                        "$ref": "admission-interviews.json#"
                    }
                }
            ],
            "additionalProperties": false,
            "required": [
                "id"
            ]
        },
        "admissionNote": {
            "title": "Note",
            "description": "The global identifier of the note for the admission application.",
            "type": "object",
            "properties": {
                "id": {
                    "title": "ID",
                    "description": "The global identifier for the Note.",
                    "type": "string",
                    "format": "guid",
                    "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                }
            },
            "links": [
                {
                    "rel": "self",
                    "href": "/admission-notes/{id}",
                    "targetSchema": {
                        "$ref": "admission-notes.json#"
                    }
                }
            ],
            "additionalProperties": false,
            "required": [
                "id"
            ]
        },
        "dfeApplicationId": {
            "title": "Dfe Application Id",
            "description": "The unique DfE ID of the application on which this decision was made.",
            "type": "string"
        },
        "status": {
            "title": "Status",
            "description": "Status of the decision",
            "enum": [
                "Success",
                "Failure"
            ],
            "type": "string"
        },
        "jobRunId": {
            "title": "Job Run Id",
            "description": "Correlation id of the job run",
            "type": "string"
        },
        "errorDetail": {
            "title": "Error Detail",
            "description": "Details of the Error occurred",
            "type": "string"
        },
        "errorDescription": {
            "title": "Error Description",
            "description": "Description of the error occurred",
            "type": "string"
        },
        "responseCode": {
            "title": "Response Code",
            "description": "Response code received while sending information to 3rd Party",
            "type": "string"
        },
        "jobRunDate": {
            "title": "Job Run Date",
            "description": "Pipeline Job run date and time",
            "type": "string",
            "format": "date-time",
            "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
        }
    },
    "required": [
        "status",
        "jobRunId"
    ],
    "additionalProperties": false
}
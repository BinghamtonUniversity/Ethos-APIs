{
  "title": "User Identity Profiles",
  "description": "Identity profile details for users to be integrated with Ethos Identity for provisioning service.",
  "type": "object",
  "properties": {
    "metadata": {
      "title": "Metadata",
      "description": "Metadata about the JSON payload",
      "type": "object",
      "properties": {
        "createdBy": {
          "title": "Created By",
          "description": "The name of the originator (user or system) of the data. This is informational only, do not use in business logic!",
          "type": "string"
        },
        "createdOn": {
          "title": "Created On",
          "description": "The date and time when the entity instance was created",
          "oneOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "modifiedBy": {
          "title": "Modified By",
          "description": "The name of the modifier (user or system) of the data. This is informational only, do not use in business logic!",
          "type": "string"
        },
        "modifiedOn": {
          "title": "Modified On",
          "description": "The date and time when the entity instance was last modified",
          "oneOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "id": {
      "title": "ID",
      "description": "The global identifier of the user-identity-profiles.",
      "type": "string",
      "format": "guid",
      "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
    },
    "udcIdentifier": {
      "title": "udcIdentifier",
      "description": "the UDCIdentifier value for person",
      "type": "string",
      "maxLength": 32
    },
    "dateOfBirth": {
      "title": "Date Of Birth",
      "description": "The date of birth of the person",
      "oneOf": [
        {
          "type": "string",
          "format": "date",
          "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])$"
        },
        {
          "type": "string",
          "maxLength": 0
        }
      ]
    },
    "bannerId": {
      "title": "bannerId",
      "description": "The spriden ID for the person",
      "type": "string"
    },
    "personIdentity": {
      "title": "Person Identity",
      "description": "person details",
      "type": "object",
      "properties": {
        "personName": {
          "title": "Person Name",
          "description": "Person name details",
          "type": "object",
          "properties": {
            "formattedName": {
              "title": "Formatted Name",
              "description": "Combination of first ,middle and last name",
              "type": "string"
            },
            "givenName": {
              "title": "Given Name",
              "description": "First name of the person",
              "type": "string"
            },
            "familyName": {
              "title": "Family Name",
              "description": "Last name of the person",
              "type": "string"
            },
            "middleName": {
              "title": "Middle Name",
              "description": "Middle name of the person",
              "type": "string"
            },
            "preferredGivenName": {
              "title": "Preferred Given Name",
              "description": "Preferred first name of the person",
              "type": "string"
            },
            "affix": {
              "title": "Affix",
              "description": "Form of address for the person.",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "title": "Type",
                    "description": "Type of the affix",
                    "type": "string"
                  },
                  "value": {
                    "title": "Value",
                    "description": "Value of the affix",
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "givenName",
            "familyName"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "personName"
      ]
    },
    "emailAddress": {
      "title": "Email Address",
      "description": "Email address of the person",
      "type": "string"
    },
    "primaryAddress": {
      "title": "Primary Address",
      "description": "Address of the person",
      "type": "object",
      "properties": {
        "postalCode": {
          "title": "Postal Code",
          "description": "Code established by postal authorities.",
          "type": "string"
        },
        "region": {
          "title": "Region",
          "description": "State or province portion of the address.",
          "type": "string"
        },
        "municipality": {
          "title": "Municipality",
          "description": "City, town, village, or hamlet portion of the address",
          "type": "string"
        },
        "addressLines": {
          "title": "Address Line",
          "description": "One formatted address line with all pieces in their proper place.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "mobilePhone": {
      "title": "Mobile Phone",
      "description": "Contact number of the person",
      "type": "object",
      "properties": {
        "areaCityCode": {
          "title": "Area City Code",
          "description": "Telephone area code.",
          "type": "string"
        },
        "subscriberNumber": {
          "title": "Subscriber Number",
          "description": "\"Local” phone number.",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "institutionRoles": {
      "title": "Institution Roles",
      "description": "Roles assigned to the person.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "principal": {
      "title": "Principal",
      "description": "Principal name of the person",
      "type": "string"
    },
    "credential": {
      "title": "Credential",
      "description": "Credential of the person",
      "type": "string"
    }
  },
  "required": [
    "id",
    "udcIdentifier",
    "personIdentity"
  ],
  "additionalProperties": false
}
{
    "title": "Aptitude Assessments",
    "description": "Assessments that are used to determine a student's aptitude (academic achievement, competency, proficiency).",
    "version": "6.1.0",
    "type": "object",
    "properties": {
        "metadata": {
            "title": "Metadata",
            "description": "Metadata about the JSON payload",
            "type": "object",
            "properties": {
                "createdBy": {
                    "title": "Created By",
                    "description": "The name of the originator (user or system) of the data. This is informational only, do not use in business logic!",
                    "type": "string"
                },
                "createdOn": {
                    "title": "Created On",
                    "description": "The date and time when the entity instance was created",
                    "oneOf": [
                        {
                            "type": "string",
                            "format": "date-time",
                            "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
                        },
                        {
                            "type": "string",
                            "maxLength": 0
                        }
                    ]
                },
                "modifiedBy": {
                    "title": "Modified By",
                    "description": "The name of the modifier (user or system) of the data. This is informational only, do not use in business logic!",
                    "type": "string"
                },
                "modifiedOn": {
                    "title": "Modified On",
                    "description": "The date and time when the entity instance was last modified",
                    "oneOf": [
                        {
                            "type": "string",
                            "format": "date-time",
                            "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])T(2[0-3]|[0-1][0-9]):([0-5][0-9]):([0-5][0-9])(\\.[0-9]+)?(Z|[+-](?:2[0-3]|[0-1][0-9]):[0-5][0-9])?$"
                        },
                        {
                            "type": "string",
                            "maxLength": 0
                        }
                    ]
                }
            },
            "additionalProperties": false
        },
        "id": {
            "title": "ID",
            "description": "The global identifier of the Aptitude Assessment.",
            "type": "string",
            "format": "guid",
            "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
        },
        "title": {
            "title": "Title",
            "description": "The full name of the Aptitude Assessment.",
            "type": "string",
            "minLength": 1
        },
        "code": {
            "title": "Code",
            "description": "The code that identifies the Aptitude Assessment.",
            "type": "string"
        },
        "description": {
            "title": "Description",
            "description": "The description of the Aptitude Assessment.",
            "type": "string"
        },
        "vendor": {
            "title": "Vendor",
            "description": "The organization that offers the assessment.",
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "ID",
                            "description": "The global identifier for the Vendor.",
                            "type": "string",
                            "format": "guid",
                            "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                        }
                    },
                    "links": [
                        {
                            "rel": "self",
                            "href": "/organizations/{id}",
                            "targetSchema": {
                                "$ref": "organizations.json#"
                            }
                        }
                    ],
                    "additionalProperties": false,
                    "required": [
                        "id"
                    ]
                },
                {
                    "type": "object",
                    "maxProperties": 0
                }
            ]
        },
        "parentAssessment": {
            "title": "Parent Assessment",
            "description": "The assessment of which the assessment is part.",
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "ID",
                            "description": "The global identifier for the Parent Assessment.",
                            "type": "string",
                            "format": "guid",
                            "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                        }
                    },
                    "links": [
                        {
                            "rel": "self",
                            "href": "/aptitude-assessments/{id}",
                            "targetSchema": {
                                "$ref": "aptitude-assessments.json#"
                            }
                        }
                    ],
                    "additionalProperties": false,
                    "required": [
                        "id"
                    ]
                },
                {
                    "type": "object",
                    "maxProperties": 0
                }
            ]
        },
        "validScores": {
            "title": "Valid Scores",
            "description": "The valid scores that may be awarded for the assessment.",
            "oneOf": [
                {
                    "title": "Values",
                    "description": "The valid literal values that may be assigned as a score for the assessment.",
                    "type": "object",
                    "properties": {
                        "values": {
                            "title": "Values",
                            "description": "The valid literal values that may be assigned as a score for the assessment.",
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "minLength": 1,
                                "type": "string"
                            }
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "values"
                    ]
                },
                {
                    "title": "Range",
                    "description": "The range of possible numeric scores on the assessment.",
                    "type": "object",
                    "properties": {
                        "range": {
                            "title": "Range",
                            "description": "The range of possible numeric scores on the assessment.",
                            "type": "object",
                            "properties": {
                                "minimum": {
                                    "title": "Minimum",
                                    "description": "The lowest possible score on the assessment.",
                                    "type": "number"
                                },
                                "maximum": {
                                    "title": "Maximum",
                                    "description": "The highest possible score on the assessment.",
                                    "type": "number"
                                },
                                "increment": {
                                    "title": "Increment",
                                    "description": "The valid increments between the minimum and maximum for assessment scores.",
                                    "oneOf": [
                                        {
                                            "type": "number"
                                        },
                                        {
                                            "type": "null"
                                        }
                                    ]
                                }
                            },
                            "additionalProperties": false,
                            "required": [
                                "minimum",
                                "maximum"
                            ]
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "range"
                    ]
                },
                {
                    "type": "object",
                    "maxProperties": 0
                }
            ]
        },
        "calculation": {
            "title": "Calculation",
            "description": "The type and method of the calculations to be used to determent the assessment score.",
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "type": {
                            "title": "Type",
                            "description": "The type of calculation to be applied the assessment score.",
                            "enum": [
                                "raw",
                                "calculated"
                            ],
                            "type": "string"
                        },
                        "method": {
                            "title": "Method",
                            "description": "The calculation method to determine the assessment's score.",
                            "oneOf": [
                                {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "title": "ID",
                                            "description": "The global identifier for the Method.",
                                            "type": "string",
                                            "format": "guid",
                                            "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                                        }
                                    },
                                    "links": [
                                        {
                                            "rel": "self",
                                            "href": "/assessment-calculation-methods/{id}",
                                            "targetSchema": {
                                                "$ref": "assessment-calculation-methods.json#"
                                            }
                                        }
                                    ],
                                    "additionalProperties": false,
                                    "required": [
                                        "id"
                                    ]
                                },
                                {
                                    "type": "object",
                                    "maxProperties": 0
                                }
                            ]
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "type"
                    ]
                },
                {
                    "type": "object",
                    "maxProperties": 0
                }
            ]
        },
        "assessmentType": {
            "title": "Assessment Type",
            "description": "The type of the assessment (e.g. admissions, placement, ...).",
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "ID",
                            "description": "The global identifier for the Assessment Type.",
                            "type": "string",
                            "format": "guid",
                            "pattern": "^[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$"
                        }
                    },
                    "links": [
                        {
                            "rel": "self",
                            "href": "/aptitude-assessment-types/{id}",
                            "targetSchema": {
                                "$ref": "aptitude-assessment-types.json#"
                            }
                        }
                    ],
                    "additionalProperties": false,
                    "required": [
                        "id"
                    ]
                },
                {
                    "type": "object",
                    "maxProperties": 0
                }
            ]
        }
    },
    "required": [
        "id",
        "title"
    ],
    "additionalProperties": false,
    "links": [
        {
            "rel": "namedQuery",
            "encType": "application/x-www-form-urlencoded",
            "method": "GET",
            "href": "/aptitude-assessments?testAndSubtest={\"testType\": {$testType} , \"subtestType\" : {$subtestType}}",
            "name": "testAndSubtest",
            "title": "Test And Subtest",
            "description": "Aptitude Assessment corresponding to the test and subtest",
            "schema": {
                "type": "object",
                "properties": {
                    "testType": {
                        "type": "string"
                    },
                    "subtestType": {
                        "type": "string"
                    }
                },
                "required": [
                    "testType",
                    "subtestType"
                ]
            },
            "targetSchema": {
                "$ref": "aptitude-assessments.json#"
            }
        }
    ]
}
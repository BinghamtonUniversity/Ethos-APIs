          "additionalProperties": false,
          "required": [
            "id"
          ]
        },
        {
          "type": "object",
          "maxProperties": 0
        }
      ]
    },
    "capitalizationStatus": {
      "title": "Capitalization Status",
      "description": "The capitalization status of the fixed asset.",
      "enum": [
        "capitalized",
        "uncapitalized",
        "nonCapital"
      ],
      "type": "string"
    },
    "acquisitionMethod": {
      "title": "Acquisition Method",

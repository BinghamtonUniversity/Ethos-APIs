                        "startOn": {
                            "title": "Start On",
                            "description": "The date when the hold goes into effect",
                            "oneOf": [
                                {
                                    "type": "string",
                                    "format": "date",
                                    "pattern": "^(-?(?:[1-9][0-9]*)?[0-9]{4})-(1[0-2]|0[1-9])-(3[0-1]|0[1-9]|[1-2][0-9])$"
                                },

                    "title": "Day",
                    "description": "The day part of the date.",
                    "oneOf": [
                      {
                        "type": "number",
                        "minimum": 0,
                        "format": "positiveInteger"
                      },
                      {
                        "type": "string",
                        "nullable": true
                      }
                    ]
                  }
                },
                "additionalProperties": false,
                "required": [
                  "year"
                ]
